# Database — LaporIn ITK
# Ganti YOUR_PASSWORD dengan password PostgreSQL kamu
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/laporin_itk

# Untuk Docker: ganti localhost dengan host.docker.internal (Mac/Windows)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@host.docker.internal:5432/laporin_itk

# JWT Authentication
SECRET_KEY=your-secret-key-ganti-dengan-random-string-panjang
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — pisahkan dengan koma jika lebih dari satu
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000